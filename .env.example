# =============================================================================
# World Cup Analytics — template de variáveis de ambiente
# Copie para .env e preencha com seus valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Settings → API no painel do projeto
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Supabase — conexão direta PostgreSQL (para run_migrations.py e análises)
# Settings → Database no painel do projeto
# -----------------------------------------------------------------------------
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_NAME=postgres
