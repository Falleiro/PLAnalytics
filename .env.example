# =============================================================================
# Premier League Analytics — template de variáveis de ambiente
# Copie para .env e preencha com seus valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Fase 2)
# Settings → API no painel do projeto
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Supabase — conexão direta PostgreSQL (para Power BI, Fase 5)
# Settings → Database no painel do projeto
# -----------------------------------------------------------------------------
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha-aqui
DB_NAME=postgres

# -----------------------------------------------------------------------------
# Azure / Power BI (Fase 6)
# portal.azure.com → App registrations
# -----------------------------------------------------------------------------
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=xxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Power BI Service → Workspace → Dataset
POWERBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_REPORT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Apache Airflow (Fase 3)
# -----------------------------------------------------------------------------
AIRFLOW_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
